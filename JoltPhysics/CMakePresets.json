{
  "version": 3,
  "cmakeMinimumRequired":
  {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets":
  [
    {
      "name": "Win_x64",
      "displayName": "Visual Studio x64",
      "description": "Default build using VS x64",
      "generator": "Visual Studio 17 2022",
      "architecture":{ "value": "x64", "strategy": "external" },
      "binaryDir": "${sourceDir}/build/Win_x64",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE":"Release",
        "CMAKE_INSTALL_PREFIX":"${sourceDir}/../Packages/JoltPhysics/Win_x64",
        "USE_AVX512":"1",
        "OBJECT_LAYER_BITS":"0",
        "DOUBLE_PRECISION":"1"
      },
      "condition":
      {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Win_arm64",
      "displayName": "Visual Studio arm64",
      "description": "Default build using VS arm64",
      "generator": "Visual Studio 17 2022",
      "architecture":{ "value": "arm64", "strategy": "external" },
      "binaryDir": "${sourceDir}/build/Win_arm64",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE":"Release",
        "CMAKE_INSTALL_PREFIX":"${sourceDir}/../Packages/JoltPhysics/Win_arm64",
        "USE_AVX512":"1",
        "OBJECT_LAYER_BITS":"0",
        "DOUBLE_PRECISION":"1"
      },
      "condition":
      {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    
    {
      "name": "Unix_x64",
      "displayName": "Unix Makefiles x64",
      "description": "Default build using Unix Makefiles x64",
      "generator": "Unix Makefiles",
      "architecture":{ "value": "x64", "strategy": "external" },
      "binaryDir": "${sourceDir}/build/Unix_x64",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE":"Release",
        "CMAKE_INSTALL_PREFIX":"${sourceDir}/../Packages/JoltPhysics/Unix_x64",
        "USE_AVX512":"1",
        "OBJECT_LAYER_BITS":"0",
        "DOUBLE_PRECISION":"1"
      },
      "condition":
      {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Unix_arm64",
      "displayName": "Unix Makefiles arm64",
      "description": "Default build using Unix Makefiles arm64",
      "generator": "Unix Makefiles",
      "architecture":{ "value": "arm64", "strategy": "external" },
      "binaryDir": "${sourceDir}/build/Unix_arm64",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE":"Release",
        "CMAKE_INSTALL_PREFIX":"${sourceDir}/../Packages/JoltPhysics/Unix_arm64",
        "USE_AVX512":"1",
        "OBJECT_LAYER_BITS":"0",
        "DOUBLE_PRECISION":"1"
      },
      "condition":
      {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "XCode",
      "displayName": "XCode",
      "description": "Default build using XCode",
      "generator": "XCode",
      "binaryDir": "${sourceDir}/build/XCode",
      "cacheVariables":
      {
        "CMAKE_BUILD_TYPE":"Release",
        "CMAKE_INSTALL_PREFIX":"${sourceDir}/../Packages/JoltPhysics/XCode",
        "USE_AVX512":"1",
        "OBJECT_LAYER_BITS":"0",
        "DOUBLE_PRECISION":"1"
      },
      "condition":
      {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ]
}
